<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outbound SMB and other network clients -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Bonjour remote-control listener (Mac Catalyst) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Mac Catalyst sandbox keys (ignored on iPhone/iPad) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
    <!-- Read mounted audio CDs (and other removable volumes) under /Volumes so
         an inserted disc can be auto-detected and its AIFF tracks streamed for
         playback, without making the user pick the volume by hand. -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-only</key>
    <array>
        <string>/Volumes/</string>
    </array>
    <!-- AVFoundation's playback path reaches audioanalyticsd over a mach
         lookup. Under the Mac Catalyst App Sandbox that lookup is blocked by
         default, which trips a precondition failure and kills the process the
         moment a track starts. Granting the lookup lets audio play. -->
    <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
    <array>
        <string>com.apple.audioanalyticsd</string>
    </array>
</dict>
</plist>
