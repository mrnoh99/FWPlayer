<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- FWPlayer does not track users across apps/websites owned by other
	     companies, runs no advertising, and contacts no tracking domains. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- No data is collected from the device. Album lookups send only the
	     track's existing artist/title text to Apple's public iTunes Search /
	     MusicKit catalog endpoints; nothing is linked to the user's identity
	     and nothing is stored off-device. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required-reason API declarations. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- @AppStorage / UserDefaults for app settings, saved SMB
			     servers, bookmarks and playlists — readable only by the app. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<!-- File modification date / size of music files the user
			     explicitly granted access to via the document picker /
			     security-scoped bookmarks, shown in the browser. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
